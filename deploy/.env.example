# Vulos Board sync server — deploy environment (server-go/).
# Copy to `.env` next to docker-compose.yml and edit before `docker compose up`.
#
#   cp .env.example .env
#
# Default values here reproduce the DEV posture: disk persistence, auth OFF.
# For production you MUST set BOARD_AUTH_SECRET and should configure the
# VULOS_STORAGE_* seam so snapshots persist to the shared bucket.

# ── Host wiring ───────────────────────────────────────────────────────────────
# Host port published by compose (container always listens on :8080). Put a
# TLS-terminating reverse proxy (board.vulos.org) in front and proxy /ws/ here.
BOARD_HOST_PORT=8080
# In-container listen address (rarely changed).
BOARD_LISTEN_ADDR=:8080

# CORS allow-list for the WebSocket upgrade (space- or comma-separated origins).
# Empty ⇒ same-origin check only. Set to the origin(s) that embed the board
# iframe, e.g. https://workspace.vulos.org https://meet.vulos.org
BOARD_ALLOWED_ORIGINS=

# ── Auth (seam A) — REQUIRED IN PRODUCTION ────────────────────────────────────
# HMAC-SHA256 secret used to verify the ?token= on each WS upgrade.
# It MUST be byte-for-byte identical across:
#   • this board server (BOARD_AUTH_SECRET),
#   • the Vulos OS control plane that mints tokens (/api/board/token), and
#   • the CP that hands the token to the board iframe.
# A token is base64url(payload).base64url(HMAC_SHA256(secret, base64url(payload)))
# with payload {"exp":<unix-seconds>,"room":"<board id>"}.
# LEAVE EMPTY ONLY FOR LOCAL DEV — empty disables auth (all connections accepted).
BOARD_AUTH_SECRET=

# ── Persistence: disk fallback (default) ──────────────────────────────────────
# Snapshot dir inside the container (mapped to the `board-data` volume). Each
# room is stored at ${BOARD_DATA_DIR}/board/<room>.bin. Used only while the
# storage seam below is unset.
BOARD_DATA_DIR=/data

# ── Persistence: bucket (opt-in — the Vulos storage seam) ─────────────────────
# Set ENDPOINT + BUCKET (both required) to persist to the shared object store
# instead of disk. Snapshots are written to <PREFIX>board/<room>.bin.
# ENDPOINT may be https://… or a loopback/private http:// (plaintext public
# endpoints are refused). Leave all blank to stay on disk.
VULOS_STORAGE_ENDPOINT=
VULOS_STORAGE_BUCKET=
VULOS_STORAGE_PREFIX=board-app/
VULOS_STORAGE_REGION=us-east-1
VULOS_STORAGE_ACCESS_KEY=
VULOS_STORAGE_SECRET_KEY=
# Optional — only for STS / temporary credentials.
VULOS_STORAGE_SESSION_TOKEN=
